{
  "name": "@rshval/svelte-components",
  "version": "1.0.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "check:deps": "node ./scripts/check-import-deps.mjs",
    "storybook": "storybook dev -p 6006 --ci --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release": "npm version patch && npm publish && git push --follow-tags",
    "smoke:exports": "node ./scripts/smoke-exports.mjs"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "default": "./dist/helpers/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "default": "./dist/plugins/index.js"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "default": "./dist/stores/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "default": "./dist/constants.js"
    }
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.53.3",
    "svelte": "^5.53.5"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@popperjs/core": "^2.11.8",
    "@storybook/addon-a11y": "^9.1.19",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/sveltekit": "^9.1.19",
    "@svelte-put/dragscroll": "^4.0.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.53.3",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-bubble-menu": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@turf/turf": "^7.3.4",
    "@vitest/browser": "4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "daisyui": "^5.5.19",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "mapbox-gl": "^3.19.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "publint": "^0.3.18",
    "storybook": "^9.1.19",
    "svelte": "^5.53.5",
    "svelte-check": "^4.4.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "uniqolor": "^1.1.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "description": "Reusable Svelte 5 UI component library (forms, table, map, notifications, drawers and stores).",
  "license": "MIT",
  "dependencies": {
    "@capacitor/core": "^7.4.3",
    "@capacitor/device": "^7.0.3",
    "@capacitor/geolocation": "^7.0.3",
    "@capacitor/network": "^7.0.3",
    "@capacitor/preferences": "^7.0.3",
    "@capacitor/screen-orientation": "^7.0.3",
    "@capacitor/status-bar": "^7.0.3",
    "@tabler/icons-svelte-runes": "^3.35.0",
    "delay": "^7.0.0",
    "dompurify": "^3.3.1",
    "esm-env": "^1.2.2",
    "libphonenumber-js": "^1.12.24"
  },
  "keywords": [
    "svelte",
    "sveltekit",
    "components",
    "ui",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rshval/svelte-components.git"
  },
  "homepage": "https://github.com/rshval/svelte-components#readme",
  "bugs": {
    "url": "https://github.com/rshval/svelte-components/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
